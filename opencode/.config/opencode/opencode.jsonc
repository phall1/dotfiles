{
    "$schema": "https://opencode.ai/config.json",
    // "share": "disabled",
    "plugin": [
      "oh-my-openagent",
      "opencode-pty",
      "file:///Users/Patrick.Hall/workspace/opencode-anthropic-auth",
      "opencode-cursor-oauth",
      "file:///Users/Patrick.Hall/.config/opencode/plugin/autoresearch"
    ],
    "instructions": [
        // "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
    ],
    "mcp": {
        "notion": {
            "type": "remote",
            "url": "https://mcp.notion.com/mcp",
        },
        "kit-dev-mcp": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "cased-kit",
                "kit-dev-mcp"
            ],
            "environment": {},
            "enabled": false
        },
        "linear": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-remote",
                "https://mcp.linear.app/mcp"
            ],
            "enabled": true
        }
    },
    "tools": {
        // "linear_*": false
    },
    "provider": {
        "cursor": {
            "name": "Cursor"
        }
    }
}
