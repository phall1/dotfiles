#!/usr/bin/env bash
# Re-applies frontmatter to context-mode's UPSTREAM-CREDITS.md so pi stops
# complaining "description is required". Safe to run repeatedly.
# Re-run after `pi update` or `npm i -g context-mode` if the warning returns.
set -euo pipefail

target="/opt/homebrew/lib/node_modules/context-mode/skills/UPSTREAM-CREDITS.md"

if [[ ! -f "$target" ]]; then
  echo "context-mode not installed at $target — nothing to do."
  exit 0
fi

if head -1 "$target" | grep -q '^---$'; then
  echo "Already patched."
  exit 0
fi

tmp=$(mktemp)
cat > "$tmp" <<'EOF'
---
description: Internal credits file for vendored upstream skills. Not user-invokable.
disable-model-invocation: true
---
EOF
cat "$target" >> "$tmp"
mv "$tmp" "$target"
echo "Patched $target"
