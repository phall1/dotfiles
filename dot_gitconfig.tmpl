[user]
	email = {{ .git.email }}
	name = {{ .git.name }}
[credential "https://github.com"]
	helper =
	helper = !{{ lookPath "gh" }} auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !{{ lookPath "gh" }} auth git-credential
[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	light = false
	line-numbers = true
	side-by-side = true
	syntax-theme = base16
[merge]
	conflictstyle = zdiff3
[diff]
	colorMoved = default
