#!/usr/bin/env sh
# yabai — tiling window manager.
# Edits to this file land in $HOME/.config/yabai/yabairc via chezmoi apply.
# Reload: yabai --restart-service     (full restart)
#         launchctl kickstart -k gui/$(id -u)/homebrew.mxcl.yabai
# Docs:   https://github.com/asmvik/yabai/wiki   (formerly koekeishiya/yabai)
#
# SIP-gated features are flagged "[SIP]" — uncomment after partial-disabling
# SIP per docs/RICE.md.

# ─── Layout ─────────────────────────────────────────────────────────────────
yabai -m config layout                       bsp
yabai -m config window_placement             second_child

# ─── Gaps & padding ─────────────────────────────────────────────────────────
yabai -m config top_padding                  4
yabai -m config bottom_padding               4
yabai -m config left_padding                 4
yabai -m config right_padding                4
yabai -m config window_gap                   4

# ─── Mouse ──────────────────────────────────────────────────────────────────
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config mouse_modifier               fn
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m mouse_drop_action                   swap

# ─── Behavior ───────────────────────────────────────────────────────────────
yabai -m config auto_balance                 off
yabai -m config split_ratio                  0.50
yabai -m config split_type                   auto

# ─── [SIP] Visuals (require disabled SIP + scripting addition) ──────────────
# yabai -m config window_shadow              float
# yabai -m config window_opacity             on
# yabai -m config active_window_opacity      1.0
# yabai -m config normal_window_opacity      0.92
# yabai -m config window_animation_duration  0.15

# ─── Rules — apps that should always float ──────────────────────────────────
yabai -m rule --add app="^System Settings$"   manage=off
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^Calculator$"        manage=off
yabai -m rule --add app="^Finder$" title="(Copy|Move|Info|Preferences|Settings|Get Info|Connect to Server|Go to Folder)" manage=off
yabai -m rule --add title="^(Downloads|Archive Utility|The Unarchiver)$" manage=off
yabai -m rule --add app="^(zoom\.us|Zoom|FaceTime|Photo Booth|Stickies|QuickTime Player)$" manage=off
yabai -m rule --add app="^(Safari|Google Chrome|Arc|Firefox|Brave Browser)$" title="^(Downloads|Save|Open|Print)" manage=off
yabai -m rule --add app="^App Store$"         manage=off
yabai -m rule --add app="^Activity Monitor$"  manage=off
yabai -m rule --add app="^1Password$"         manage=off
yabai -m rule --add app="^Raycast$"           manage=off
yabai -m rule --add title="^Preferences$"     manage=off

# Cheat-sheet popup (alt+slash in skhd) — floats centered, ~60% screen.
yabai -m rule --add title="^rice-cheatsheet$" manage=off grid=10:10:2:2:6:6

# Ghostty's quick-terminal dropdown — float it (doesn't belong in tiling tree).
yabai -m rule --add app="^[gG]hostty$" title="^Quick Terminal" manage=off

# ─── Signals — keep sketchybar in sync with window/space events ─────────────
yabai -m signal --add event=window_focused   action="sketchybar --trigger window_focus"
yabai -m signal --add event=window_created   action="sketchybar --trigger windows_on_spaces"
yabai -m signal --add event=window_destroyed action="sketchybar --trigger windows_on_spaces"

echo "yabai configuration loaded"
