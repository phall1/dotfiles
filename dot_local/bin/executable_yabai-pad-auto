#!/usr/bin/env bash
# yabai-pad-auto — collapse side/bottom padding + window_gap to 0 when the
# focused space has a single visible managed window (incl. native fullscreen);
# restore to MULTI when 2+. top_padding is left at 0 always (external_bar
# reserves sketchybar's height in yabairc).
#
# Wired from yabairc via window_{created,destroyed,focused},
# space_changed, application_{launched,terminated} signals.

set -eu

SOLO=0
MULTI=6

space=$(yabai -m query --spaces --space 2>/dev/null | jq -r '.index // empty') || exit 0
[ -n "$space" ] || exit 0

count=$(yabai -m query --windows --space 2>/dev/null \
  | jq '[.[] | select(."is-visible" and (."is-floating"|not) and (."is-minimized"|not))] | length') || exit 0

if [ "$count" -le 1 ]; then
  pad=$SOLO
else
  pad=$MULTI
fi

yabai -m config --space "$space" left_padding   "$pad"
yabai -m config --space "$space" right_padding  "$pad"
yabai -m config --space "$space" bottom_padding "$pad"
yabai -m config --space "$space" window_gap     "$pad"
