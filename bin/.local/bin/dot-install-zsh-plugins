#!/usr/bin/env bash
# dot-install-zsh-plugins — bootstrap zsh plugins from zsh/plugins.lock.
#
# Idempotent: skips plugins already at the pinned ref, fetches+checks-out
# otherwise. Safe to re-run any time.

set -uo pipefail

DOTFILES="${DOTFILES:-$HOME/dotfiles}"
PLUGIN_DIR="${ZSH_PLUGIN_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins}"
LOCK="$DOTFILES/zsh/plugins.lock"

RED=$'\033[31m'; GRN=$'\033[32m'; YLW=$'\033[33m'; DIM=$'\033[2m'; RST=$'\033[0m'

[[ -f "$LOCK" ]] || { echo "${RED}missing lockfile: $LOCK${RST}" >&2; exit 2; }

mkdir -p "$PLUGIN_DIR"

failed=0
installed=0
updated=0
ok=0

while read -r name repo ref; do
  [[ -z "$name" || "$name" =~ ^# ]] && continue

  target="$PLUGIN_DIR/$name"
  url="https://github.com/$repo"

  if [[ ! -d "$target/.git" ]]; then
    printf "${DIM}%-26s cloning %s @ %s${RST}\n" "$name" "$repo" "$ref"
    if ! git clone --quiet --depth 1 --branch "$ref" "$url" "$target" 2>/dev/null \
       && ! git clone --quiet "$url" "$target"; then
      printf "  ${RED}clone failed${RST}\n"
      failed=$((failed + 1))
      continue
    fi
    if [[ -d "$target/.git" ]] && ! git -C "$target" rev-parse "$ref" >/dev/null 2>&1; then
      git -C "$target" fetch --quiet origin "$ref" 2>/dev/null || true
    fi
    git -C "$target" checkout --quiet "$ref" 2>/dev/null || true
    installed=$((installed + 1))
    continue
  fi

  current=$(git -C "$target" rev-parse HEAD)
  current_short=$(git -C "$target" rev-parse --short HEAD)
  desired=$(git -C "$target" rev-parse "$ref" 2>/dev/null || echo "")

  if [[ -z "$desired" ]]; then
    git -C "$target" fetch --quiet origin 2>/dev/null || true
    desired=$(git -C "$target" rev-parse "$ref" 2>/dev/null || echo "")
  fi

  if [[ "$current" == "$desired" ]]; then
    printf "${GRN}%-26s${RST} ${DIM}%s @ %s${RST}\n" "$name" "$repo" "$current_short"
    ok=$((ok + 1))
  else
    printf "${YLW}%-26s${RST} updating %s → %s\n" "$name" "$current_short" "$(git -C "$target" rev-parse --short "$ref" 2>/dev/null)"
    git -C "$target" checkout --quiet "$ref" 2>/dev/null || git -C "$target" reset --hard "$ref"
    updated=$((updated + 1))
  fi
done < "$LOCK"

echo
printf "${DIM}ok=%d installed=%d updated=%d failed=%d  plugin dir: %s${RST}\n" "$ok" "$installed" "$updated" "$failed" "$PLUGIN_DIR"

[[ "$failed" -gt 0 ]] && exit 2
exit 0
