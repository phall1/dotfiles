{
    "$schema": "https://opencode.ai/config.json",
    "plugin": [
        "opencode-pty"
    ],
    "instructions": [],
    "mcp": {
        "kit-dev-mcp": {
            "type": "local",
            "command": [
                "uvx",
                "--from",
                "cased-kit",
                "kit-dev-mcp"
            ],
            "environment": {},
            "enabled": false
        },
        "linear": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "mcp-remote",
                "https://mcp.linear.app/mcp"
            ],
            "enabled": true
        }
    },
    "tools": {},
    "provider": {}
}
